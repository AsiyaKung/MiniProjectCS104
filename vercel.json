{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "python",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
